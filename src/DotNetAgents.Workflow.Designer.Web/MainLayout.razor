@inherits LayoutComponentBase

<div class="workflow-shell @(_darkMode ? "theme-dark" : "theme-light")">
    <aside class="workflow-shell__sidebar">
        <a class="workflow-shell__brand" href="">
            <span>WF</span>
            <strong>Workflow Studio</strong>
        </a>
        <nav class="workflow-shell__nav">
            <NavLink class="workflow-shell__nav-link" href="" Match="NavLinkMatch.All">Overview</NavLink>
            <NavLink class="workflow-shell__nav-link" href="designer">Designer</NavLink>
            <NavLink class="workflow-shell__nav-link" href="workflows">Workflows</NavLink>
        </nav>
    </aside>
    <div class="workflow-shell__main">
        <div class="workflow-topbar">
            <div>
                <strong>DotNetAgents Workflow Designer</strong>
                <span>Visual orchestration and runtime diagnostics</span>
            </div>
            <button class="btn btn-sm btn-outline-primary" @onclick="ToggleTheme">
                @(_darkMode ? "Light theme" : "Dark theme")
            </button>
        </div>
        <main class="workflow-shell__content">
            @Body
        </main>
    </div>
</div>

@code {
    private bool _darkMode;

    private void ToggleTheme() => _darkMode = !_darkMode;
}
