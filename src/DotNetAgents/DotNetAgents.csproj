    <PackageReference Include="DotNetAgents.Storage.Agents.PostgreSQL" Version="1.0.0" Condition="!Exists('..\DotNetAgents.Storage.Agents.PostgreSQL\DotNetAgents.Storage.Agents.PostgreSQL.csproj')" />


