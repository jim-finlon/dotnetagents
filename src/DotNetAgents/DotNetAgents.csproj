    <PackageReference Include="DotNetAgents.VectorStores.PostgreSQL" Version="1.0.0" Condition="!Exists('..\DotNetAgents.VectorStores.PostgreSQL\DotNetAgents.VectorStores.PostgreSQL.csproj')" />
    <PackageReference Include="DotNetAgents.VectorStores.Weaviate" Version="1.0.0" Condition="!Exists('..\DotNetAgents.VectorStores.Weaviate\DotNetAgents.VectorStores.Weaviate.csproj')" />
