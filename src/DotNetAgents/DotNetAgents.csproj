    <PackageReference Include="DotNetAgents.Agents.Messaging.SignalR" Version="1.0.0" Condition="!Exists('..\DotNetAgents.Agents.Messaging.SignalR\DotNetAgents.Agents.Messaging.SignalR.csproj')" />



